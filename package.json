{
  "name": "hsk-learning-app",
  "version": "3.1.0",
  "description": "HSK Chinese Learning Application - Static site with GitHub Pages and Firebase",
  "scripts": {
    "dev": "npm run assemble && npx serve . -p 3369",
    "assemble": "node scripts/build/assemble-index.js",
    "build": "npm run assemble && node scripts/build/build-dist.js",
    "check:cache-versions": "node scripts/build/apply-cache-versions.js",
    "check:index-assembled": "node scripts/ci/check-index-assembled.js",
    "check:syntax": "node scripts/ci/check-syntax.js",
    "check:strokes-catalog": "node scripts/ci/check-strokes-radicals-catalog.js",
    "check:past-exams": "node scripts/ci/check-past-exams-availability.js",
    "check:snake-quantifiers": "node scripts/ci/check-quantifier-snake-data.js",
    "ci": "npm run check:index-assembled && npm run check:syntax && npm run check:cache-versions && npm run check:strokes-catalog && npm run check:past-exams && npm run check:snake-quantifiers && npm run test:unit",
    "test": "npm run ci",
    "test:unit": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "translation:report": "node scripts/translation/coverage-report.js --report docs/development/translation/coverage-report.json",
    "translation:report:strict": "node scripts/translation/coverage-report.js --strict --report docs/development/translation/coverage-report.json",
    "translation:worklist": "node scripts/translation/generate-worklist.js --output docs/development/translation/hsk_es_worklist.json",
    "translation:lesson-template:hsk4": "node scripts/translation/generate-lesson-order-template.js --level 4 --output docs/development/translation/hsk4_lesson_order_template.json",
    "translation:lesson-block:hsk4-l1": "node scripts/translation/create-lesson-block-from-template.js --book shang --lesson 1 --start 0 --count 40 --output docs/development/translation/hsk4_shang_lesson_01_draft.json",
    "translation:lesson-merge:hsk4-l1:dry": "node scripts/translation/merge-lesson-draft-into-map.js --draft docs/development/translation/hsk4_shang_lesson_01_draft.json",
    "translation:lesson-merge:hsk4-l1:apply": "node scripts/translation/merge-lesson-draft-into-map.js --draft docs/development/translation/hsk4_shang_lesson_01_draft.json --write",
    "translation:lesson-order:dry": "node scripts/translation/apply-lesson-order.js",
    "translation:lesson-order:apply": "node scripts/translation/apply-lesson-order.js --write",
    "translation:lesson-order:strict": "node scripts/translation/apply-lesson-order.js --write --strict-map"
  },
  "keywords": [
    "hsk",
    "chinese",
    "learning",
    "flashcards",
    "github-pages",
    "firebase"
  ],
  "author": "Alejandro Rollano",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.59.1",
    "jsdom": "^29.1.1",
    "pinyin-pro": "^3.28.1",
    "vitest": "^4.1.10"
  }
}
