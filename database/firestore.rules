// Firestore Security Rules for HSK Learning App
// These rules ensure that users can only access their own data
// while allowing public read access to the leaderboard

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // User Profiles collection
    // Users can read any profile (for leaderboard), but only update their own
    match /user_profiles/{userId} {
      allow read: if true; // Public read for leaderboard
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }
    
    // User Progress collection
    // Users can only access their own progress
    match /user_progress/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
    
    // Word Progress collection
    // Users can only access their own word progress
    match /word_progress/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
    
    // Quiz Results collection
    // Users can only access their own quiz results
    match /quiz_results/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false; // Quiz results are immutable
    }
    
    // Matrix Scores collection
    // Users can only access their own scores, but leaderboard reads all
    match /matrix_scores/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false; // Scores are immutable
    }
    
    // Study Sessions collection
    // Users can only access their own study sessions
    match /study_sessions/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false; // Sessions are immutable
    }
    
    // Leaderboard collection (denormalized view for performance)
    // Public read access, but only admins can write (via Cloud Functions)
    match /leaderboard/{userId} {
      allow read: if true; // Public read
      allow write: if false; // Only Cloud Functions can update
    }
    
    // User Achievements collection
    // Users can only access their own achievements
    match /user_achievements/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false; // Achievements are immutable
    }
  }
}
